<?xml version='1.0' encoding='UTF-8'?>
<configuration>
  <input>
    <net-file value="../../network/osm.net.xml"/>
    <route-files value="../../demand/generated/osm_net_mappo.rou.xml"/>
    <additional-files value="../../network/tls_overrides.add.xml.gz"/>
  </input>
  <time>
    <begin value="0"/>
    <end value="1500"/>
    <step-length value="1.0"/>
  </time>
  <processing>
    <time-to-teleport value="300"/>
    <ignore-route-errors value="true"/>
  </processing>
  <report>
    <no-step-log value="true"/>
  </report>
</configuration>
